---
const notifications = [
  { text: "🎉 Tin nóng: Station chuyển sang địa chỉ mới từ 20/07/2026, truy cập vào đường dẫn này để được chuyển hướng", url: "https://builetuananh.substack.com" }
];
---
<style>
  @keyframes ticker-scroll {
    0% {
      transform: translateX(100%);
    }
    100% {
      transform: translateX(-100%);
    }
  }

  .ticker-content {
    animation: ticker-scroll 30s linear infinite;
    will-change: transform;
  }

  .ticker-content:hover {
    animation-play-state: paused;
  }
</style>

<div class="w-full overflow-hidden whitespace-nowrap bg-[#01AD9F] text-white text-base font-medium py-3 px-4 sticky top-0 z-50">
  <div class="ticker-content inline-block pl-full">
    {notifications.map(({ text, url }) => (
      url ? (
        <a
          href={url}
          class="inline-block mr-8 text-white no-underline focus:outline-none"
        >
          {text}
        </a>
      ) : (
        <span class="inline-block mr-8">{text}</span>
      )
    ))}
  </div>
</div>
